# 飞书凭证配置示例
# 复制此文件到 ~/.openclaw/.feishu-credentials
# 然后编辑配置你的真实飞书应用信息
# 权限要求：chmod 600 ~/.openclaw/.feishu-credentials

[default]
# 默认飞书应用
app_id = cli_xxxxxxxxxxxxx
app_secret = xxxxxxxxxxxxxxx
default_chat_id = ou_xxxxxxxxxxxxx

# [backup]
# 备用飞书应用（可选，取消注释并配置）
# app_id = cli_yyyyyyyyyyyyy
# app_secret = yyyyyyyyyyyyyyyyy
# default_chat_id = ou_yyyyyyyyyyyyy
