# 阿里云邮箱凭证配置示例
# 复制此文件到 ~/.openclaw/.email-credentials
# 然后编辑配置你的真实邮箱信息
# 权限要求：chmod 600 ~/.openclaw/.email-credentials

[main]
# 主工作邮箱
email = your-email@company.com
imap_server = imap.qiye.aliyun.com
imap_port = 993
auth_code = your-auth-code-here
ssl = true

# [personal]
# 个人邮箱（可选，取消注释并配置）
# email = personal@gmail.com
# imap_server = imap.gmail.com
# imap_port = 993
# auth_code = your-gmail-app-password
# ssl = true
